rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Each barber has their own folder. Public can read (so the logo shows
    // on the public booking page); only the owner can upload, with a 2 MB
    // size limit to prevent abuse.
    match /barbers/{uid}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
