rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
    function isString(f, max) {
      return f is string && f.size() > 0 && f.size() <= max;
    }
    function isPhone(f) {
      return f is string && f.size() >= 9 && f.size() <= 15 && f.matches('^[0-9+\\-\\s]+$');
    }
    function isDateStr(f) {
      return f is string && f.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }
    function isTimeStr(f) {
      return f is string && f.matches('^\\d{2}:\\d{2}$');
    }

    // Public can read barber profile (for booking page); only owner can write
    // EXCEPT the `subscription` field, which only the Cloudflare Worker can
    // write (via Firebase Admin SDK with elevated credentials). This prevents
    // a user from typing into devtools and granting themselves a subscription.
    match /barbers/{uid} {
      allow read: if true;
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
                    && !('subscription' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if isOwner(uid);

      // Clients sub-collection: anyone can create / read a single client by phone (login).
      // Only owner can list/modify.
      match /clients/{phone} {
        allow read, list: if isOwner(uid);
        allow get: if true;
        // Owner: full create freedom (dashboard quick-book may have one-word names, etc.)
        allow create: if isOwner(uid);
        // Public booking page: strict validation
        allow create: if isString(request.resource.data.firstName, 50)
                      && isString(request.resource.data.lastName, 50)
                      && isPhone(request.resource.data.phone)
                      && request.resource.data.phone == phone;
        allow update, delete: if isOwner(uid);
      }

      // Bookings: anyone can read (so clients can fetch availability), create new bookings,
      // and cancel their own (status booked → cancelled). Only owner can list/update/delete.
      match /bookings/{bookingId} {
        allow read: if true;
        allow list: if isOwner(uid);
        // Owner: can create any booking (manual dashboard entries — phone may be empty)
        allow create: if isOwner(uid);
        // Public booking page: strict validation
        allow create: if isDateStr(request.resource.data.date)
                      && isTimeStr(request.resource.data.time)
                      && isString(request.resource.data.clientName, 100)
                      && isPhone(request.resource.data.clientPhone)
                      && request.resource.data.status == 'booked';
        allow update: if isOwner(uid);
        // Public cancellation — anyone with the booking path can switch
        // status booked → cancelled (clientPhone must be preserved)
        allow update: if resource.data.clientPhone == request.resource.data.clientPhone
                      && request.resource.data.status == 'cancelled'
                      && resource.data.status == 'booked';
        // Public reschedule — anyone with the booking path (i.e., the
        // client who has their manage token) can change date and/or time
        // while keeping the booking active and clientPhone unchanged.
        allow update: if resource.data.clientPhone == request.resource.data.clientPhone
                      && resource.data.status == 'booked'
                      && request.resource.data.status == 'booked'
                      && isDateStr(request.resource.data.date)
                      && isTimeStr(request.resource.data.time);
        allow delete: if isOwner(uid);
      }

      // Blocks: barber-only manage; public can READ to compute availability but NOT list arbitrarily.
      // Allow query by date so booking page can fetch blocks for a specific day.
      match /blocks/{blockId} {
        allow read: if true;
        allow create, update, delete: if isOwner(uid);
      }

      // Expenses: business expense tracking. Owner only — never exposed publicly.
      match /expenses/{expenseId} {
        allow read, list: if isOwner(uid);
        allow create, update, delete: if isOwner(uid);
      }

      // Waitlist: client can subscribe (create); only owner reads/lists/deletes
      match /waitlist/{entryId} {
        allow read, list: if isOwner(uid);
        allow create: if isPhone(request.resource.data.clientPhone)
                      && isString(request.resource.data.clientName, 100)
                      && isDateStr(request.resource.data.fromDate)
                      && isDateStr(request.resource.data.toDate);
        allow delete: if isOwner(uid);
      }
    }

    // Short code lookup → barberId. Public read, owner-only write.
    match /shortCodes/{code} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.uid == request.auth.uid;
    }

    // Promo codes — read-only for clients (validation happens server-side via Worker).
    // Writes are done only by the Cloudflare Worker with Admin SDK credentials.
    match /promoCodes/{code} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Manage tokens — public read (the token IS the credential), public
    // create with strict structure validation. No update/delete from
    // clients. The token's secrecy + length (20 random chars) prevents
    // guessing.
    match /manageTokens/{token} {
      allow read: if true;
      allow create: if request.resource.data.uid is string
                    && request.resource.data.bookingId is string;
      allow update, delete: if false;
    }
  }
}
