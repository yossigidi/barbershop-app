rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
    function isString(f, max) {
      return f is string && f.size() > 0 && f.size() <= max;
    }
    function isPhone(f) {
      return f is string && f.size() >= 9 && f.size() <= 15 && f.matches('^[0-9+\\-\\s]+$');
    }
    function isDateStr(f) {
      // YYYY-MM-DD
      return f is string && f.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }
    function isTimeStr(f) {
      // HH:MM
      return f is string && f.matches('^\\d{2}:\\d{2}$');
    }

    // Public can read barber profile (for booking page); only owner can write
    match /barbers/{uid} {
      allow read: if true;
      allow create: if isOwner(uid);
      allow update, delete: if isOwner(uid);

      // Clients sub-collection: anyone can create a client doc (registration);
      // only owner of the barber doc can read/list/modify. Document ID = phone.
      match /clients/{phone} {
        allow read, list: if isOwner(uid);
        allow get: if true; // single client lookup by phone (login)
        allow create: if isString(request.resource.data.firstName, 50)
                      && isString(request.resource.data.lastName, 50)
                      && isPhone(request.resource.data.phone)
                      && request.resource.data.phone == phone;
        allow update, delete: if isOwner(uid);
      }

      // Bookings: anyone can create a booking; only owner can list/update/delete.
      // A client can read+delete their own booking by ID (cancellation link).
      match /bookings/{bookingId} {
        allow read: if true;
        allow list: if isOwner(uid);
        allow create: if isDateStr(request.resource.data.date)
                      && isTimeStr(request.resource.data.time)
                      && isString(request.resource.data.clientName, 100)
                      && isPhone(request.resource.data.clientPhone)
                      && request.resource.data.status == 'booked';
        allow update: if isOwner(uid);
        // Allow client cancellation: must keep same phone; only status changes to 'cancelled'
        allow update: if resource.data.clientPhone == request.resource.data.clientPhone
                      && request.resource.data.status == 'cancelled'
                      && resource.data.status == 'booked';
        allow delete: if isOwner(uid);
      }
    }

    // Short code lookup → barberId. Public read, owner-only write.
    match /shortCodes/{code} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.uid == request.auth.uid;
    }
  }
}
